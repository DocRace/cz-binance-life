# Static SPA only (Freedom of Money / cz-binance-life).
# Build with IPDEX test/prod VITE_* vars so API origins and BFF URL are correct.

FROM node:22-alpine AS build
WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

# Inlined at build time by Vite (use your test env values).
ARG VITE_IPDEX_MARKET_URL=
ARG VITE_IPDEX_URL=
ARG VITE_IPDEX_BOOK_PRIMARY_SALE_ID=
ARG VITE_IPDEX_BOOK_PRIMARY_LISTING_ID=
ARG VITE_IPDEX_NFT_REDEMPTION_RULE_ID=
ARG VITE_IPDEX_BOOK_ATTEND_STUB_SERIES_ID=
ARG VITE_IPDEX_BOOK_ATTEND_STUB_SERIES_IDS=
ARG VITE_IPDEX_CLIENT_API_ORIGIN=https://ipdex-v1-dev.ipdex.vip
ARG VITE_IPDEX_SOCIAL_X_URL=
ARG VITE_IPDEX_SOCIAL_FACEBOOK_URL=
ARG VITE_DATADANCE_EXPLORER_URL=https://scan.datadance.ai
ARG VITE_BOOK_BFF_URL=

ENV VITE_IPDEX_MARKET_URL=$VITE_IPDEX_MARKET_URL
ENV VITE_IPDEX_URL=$VITE_IPDEX_URL
ENV VITE_IPDEX_BOOK_PRIMARY_SALE_ID=$VITE_IPDEX_BOOK_PRIMARY_SALE_ID
ENV VITE_IPDEX_BOOK_PRIMARY_LISTING_ID=$VITE_IPDEX_BOOK_PRIMARY_LISTING_ID
ENV VITE_IPDEX_NFT_REDEMPTION_RULE_ID=$VITE_IPDEX_NFT_REDEMPTION_RULE_ID
ENV VITE_IPDEX_BOOK_ATTEND_STUB_SERIES_ID=$VITE_IPDEX_BOOK_ATTEND_STUB_SERIES_ID
ENV VITE_IPDEX_BOOK_ATTEND_STUB_SERIES_IDS=$VITE_IPDEX_BOOK_ATTEND_STUB_SERIES_IDS
ENV VITE_IPDEX_CLIENT_API_ORIGIN=$VITE_IPDEX_CLIENT_API_ORIGIN
ENV VITE_IPDEX_SOCIAL_X_URL=$VITE_IPDEX_SOCIAL_X_URL
ENV VITE_IPDEX_SOCIAL_FACEBOOK_URL=$VITE_IPDEX_SOCIAL_FACEBOOK_URL
ENV VITE_DATADANCE_EXPLORER_URL=$VITE_DATADANCE_EXPLORER_URL
ENV VITE_BOOK_BFF_URL=$VITE_BOOK_BFF_URL

RUN npm run build

FROM nginx:1.27-alpine
COPY deploy/nginx.spa-only.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
