# Copy to `.env.spa` on the build host; used as --env-file for docker compose SPA build args.
# Do not put secrets here (VITE_* is public in the bundle).

VITE_IPDEX_CLIENT_API_ORIGIN=https://ipdex-v1-dev.ipdex.vip
# Market SPA origin (Primary tab /collection/sales/:id). Dev test:
VITE_IPDEX_MARKET_URL=https://ipdex-v1-dev.ipdex.vip
VITE_IPDEX_URL=

# Primary sale «CZ NFT Sell 2» — NFT series «CZ NFT Test 2» (dev DB; replace when prod / admin rotates)
VITE_IPDEX_BOOK_PRIMARY_SALE_ID=bada09ad-3a04-41e0-99ab-c882ee977663
VITE_IPDEX_BOOK_PRIMARY_LISTING_ID=a6d4e2eb-1c33-4569-b988-333656580ea3
VITE_IPDEX_BOOK_PRIMARY_PRICE_HKD=299

# When IPDEX enables multiple NFT redemption DB rules — pass admin rule UUID to `/club/redeem` («CZ NFT Redeem 2» on dev).
VITE_IPDEX_NFT_REDEMPTION_RULE_ID=1b56d531-7e14-446b-9830-5ce95d3f265f
# Payout / «attendance stub» series UUID — Admin redemption rule payout collection «CZ Stub NFT Test 2»; hide Redeem on these in Account UI.
VITE_IPDEX_BOOK_ATTEND_STUB_SERIES_ID=7e93048f-120b-4a42-9b0b-4bc6311404bd
VITE_IPDEX_SOCIAL_X_URL=
VITE_IPDEX_SOCIAL_FACEBOOK_URL=
VITE_DATADANCE_EXPLORER_URL=https://scan.datadance.ai
VITE_DATADANCE_SITE_URL=https://datadance.ai
