# Copy to `bff.env` next to docker-compose.cz-life-test.yml (never commit real secrets).

IPDEX_CLIENT_ORIGIN=https://ipdex-v1-dev.ipdex.vip
IPDEX_GATEWAY_PREFIX=
IPDEX_PARTNER_COBRAND_PREFIX=/partner/integration/book-site

IPDEX_PARTNER_APP_KEY=
IPDEX_PARTNER_APP_SECRET=

# Default primary listing (`POST /api/bff/orders/primary` bodies may omit listingId). «CZ NFT Sell 2» listing on dev (`t_primary_listings`).
BOOK_PRIMARY_LISTING_ID=a6d4e2eb-1c33-4569-b988-333656580ea3

# Free STANDARD tier — Admin → Airdrop campaign → publicCode
BOOK_STANDARD_AIRDROP_PUBLIC_CODE=cz-nft-free-test-2

BFF_PORT=8787
BOOK_ALLOWED_ORIGINS=https://czlife.club,https://www.czlife.club
BOOK_COOKIE_SECURE=1

# Stripe Checkout success → {origin}/purchase-success?orderId=… (requires matching IPDEX COBRAND_BOOK_STRIPE_CALLBACK)
BOOK_STRIPE_CALLBACK_ORIGIN=https://czlife.club
