# Copy to `.env` and adjust for your deployment.
# Anything prefixed `VITE_` is inlined into client bundles — do not store secrets here.

# IPDEX marketplace SPA origin (no trailing slash)
VITE_IPDEX_MARKET_URL=http://localhost:3001

# Fallback if MARKET_URL is empty
VITE_IPDEX_URL=

# Primary sale UUID for Freedom of Money listing (`/collection/sales/:id`, from admin — e.g. "CZ NFT Sell")
VITE_IPDEX_BOOK_PRIMARY_SALE_ID=

# Primary listing UUID for Client Service `POST /ip/primary/purchase` (see GET `/market/ip/primary/sales/:salesId`)
VITE_IPDEX_BOOK_PRIMARY_LISTING_ID=

# Optional: shown in purchase modal until sale detail loads; HK dollars (sale stores cents server-side — e.g. `299`).
VITE_IPDEX_BOOK_PRIMARY_PRICE_HKD=

# Optional: Admin NFT redemption rule UUID when multiple DB rules exist (passed to Partner `/club/redeem`).
# VITE_IPDEX_NFT_REDEMPTION_RULE_ID=

# Optional: payout / attendance stub NFT series UUID (Admin redemption rule payout collection — book UI hides Redeem here).
VITE_IPDEX_BOOK_ATTEND_STUB_SERIES_ID=
# Multiple UUIDs supported (comma/space/semicolon).
# VITE_IPDEX_BOOK_ATTEND_STUB_SERIES_IDS=

# IPDEX Client Service URL (HTTPS origin only; used for Partner API label in UI)
VITE_IPDEX_CLIENT_API_ORIGIN=https://ipdex-v1-dev.ipdex.vip

# Social links shown in footer
VITE_IPDEX_SOCIAL_X_URL=https://x.com/ipdex
VITE_IPDEX_SOCIAL_FACEBOOK_URL=https://facebook.com/ipdex

# DataDance block explorer origin
VITE_DATADANCE_EXPLORER_URL=https://scan.datadance.ai

# DataDance product site (footer link; default in code is https://datadance.ai)
# VITE_DATADANCE_SITE_URL=https://datadance.ai

# Vite dev server only: forwards same-origin `/api/v1/*` to IPDEX backend (avoid CORS locally)
DEV_IPDEX_API_PROXY_TARGET=https://ipdex-v1-dev.ipdex.vip

# Vite dev: proxy /api/bff -> local book BFF (see bff/.env)
DEV_BOOK_BFF_TARGET=http://127.0.0.1:8787

# Production only: absolute URL of book BFF if different from SPA origin
# VITE_BOOK_BFF_URL=
