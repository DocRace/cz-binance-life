# IPDEX Client Service (no trailing slash)
IPDEX_CLIENT_ORIGIN=http://127.0.0.1:3000
# Prefix if your gateway exposes e.g. /api/v1 before routes (often empty for direct client service)
IPDEX_GATEWAY_PREFIX=
# Dev test host example (HTTPS + gateway): IPDEX_CLIENT_ORIGIN=https://ipdex-v1-dev.ipdex.vip and IPDEX_GATEWAY_PREFIX=/api/v1
# HMAC path must match what nginx forwards: URL = /api/v1/partner/integration/book-site/... (+ query)
# Integration façade path on Client Service — must match coBrandedIntegration prefix
IPDEX_PARTNER_COBRAND_PREFIX=/partner/integration/book-site

# Partner HMAC (same model as VERIFICATION_APP_* on Client Service — never expose to browser)
IPDEX_PARTNER_APP_KEY=partner_local
IPDEX_PARTNER_APP_SECRET=your-partner-secret-change-me
# Ensure Client Service .env.market.server sets VERIFICATION_APP_KEY/SECRET (or VERIFICATION_APP_KEYS) to THIS SAME PAIR — otherwise upstream returns code -10011 Access denied.

# Default primary listing for POST /orders/primary when body omits listingId.
# Singapore dev («CZ NFT Sell 2»): a6d4e2eb-1c33-4569-b988-333656580ea3 — see deploy/bff.env.example
BOOK_PRIMARY_LISTING_ID=

# Standard tier airdrop — Admin → Airdrop campaign → publicCode (must match SPA VITE_IPDEX_BOOK_STANDARD_AIRDROP_PUBLIC_CODE).
BOOK_STANDARD_AIRDROP_PUBLIC_CODE=

# Book-site SPA → POST /api/bff/club/redeem (partner façade POST {COBRAND}/club/redeem).
# Optional JSON body field: redemptionRuleId (UUID) when IPDEX enables multiple NFT redemption DB rules at once.
# Requires IPDEX Client Service: BOOK_CLUB_* env + migration t_book_club_redeem_request + stub primary listing inventory.
# See: ipdex-backend-v1/docs/partner/EXTERNAL_BOOK_PARTNER_API.md § BOOK_CLUB_*

# BFF
BFF_PORT=8787
# Comma-separated browser origins allowed (book SPA)
BOOK_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
